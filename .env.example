# ============================================================
# NAT Project — Root .env.example
# Copy to .env and fill in values before deploying
# ============================================================

# App URLs
APP_URL=https://app.natproject.local
API_URL=https://api.natproject.local
WS_URL=wss://api.natproject.local

# Web Ports (Coolify will override these)
WEB_PORT=3000
API_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
N8N_PORT=5678

# PostgreSQL
POSTGRES_DB=natproject
POSTGRES_USER=natuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# JWT (generate: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_REFRESH_SECRET

# NextAuth
NEXTAUTH_SECRET=CHANGE_ME_MIN_32_CHARS_NEXTAUTH_SECRET

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET=natproject

# n8n
N8N_HOST=n8n.natproject.local
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://n8n.natproject.local
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# WhatsApp (Evolution API)
WHATSAPP_EVOLUTION_URL=
WHATSAPP_EVOLUTION_KEY=
WHATSAPP_INSTANCE=natproject

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
