# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://natuser:natpassword@localhost:5432/natproject?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-min-32-chars-jwt-secret-here
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Azure AD (Microsoft)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_CALLBACK_URL=http://localhost:3001/auth/microsoft/callback

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NAT Project <noreply@natproject.app>"

# S3 / Object Storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=natproject
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# WhatsApp (Evolution API)
WHATSAPP_EVOLUTION_URL=http://localhost:8080
WHATSAPP_EVOLUTION_KEY=
WHATSAPP_INSTANCE=natproject

# n8n
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# App URL
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
